rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email in ['fhldid00@gmail.com'];
    }

    function isOwner() {
      return signedIn() && resource.data.uid == request.auth.uid;
    }

    function isValidAuthor() {
      return request.resource.data.author is string
        && request.resource.data.author.size() > 0
        && request.resource.data.author.size() <= 40;
    }

    function hasValidCreatorUid() {
      return signedIn()
        ? request.resource.data.uid == request.auth.uid
        : request.resource.data.uid == null;
    }

    function hasValidAuthorRole() {
      return request.resource.data.authorRole is string
        && request.resource.data.authorRole in ['admin', 'user', 'anonymous']
        && (isAdmin()
          ? request.resource.data.authorRole == 'admin'
          : signedIn()
            ? request.resource.data.authorRole == 'user'
            : request.resource.data.authorRole == 'anonymous');
    }

    function isValidPostCreate() {
      return request.resource.data.keys().hasOnly(['title', 'content', 'createdAt', 'uid', 'author', 'authorRole'])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 80
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 5000
        && request.resource.data.createdAt == request.time
        && isValidAuthor()
        && hasValidCreatorUid()
        && hasValidAuthorRole();
    }

    function isValidCommentCreate() {
      return request.resource.data.keys().hasOnly(['content', 'createdAt', 'updatedAt', 'uid', 'author', 'authorRole'])
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 5000
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == null
        && isValidAuthor()
        && hasValidCreatorUid()
        && hasValidAuthorRole();
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isValidPostCreate();
      allow update: if isOwner() || isAdmin();
      allow delete: if isOwner() || isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isValidCommentCreate();
        allow update: if isOwner() || isAdmin();
        allow delete: if isOwner() || isAdmin();
      }
    }
  }
}
