rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email in ['fhldid00@gmail.com'];
    }

    function isOwner() {
      return signedIn() && resource.data.uid == request.auth.uid;
    }

    function isValidAuthor() {
      return request.resource.data.author is string
        && request.resource.data.author.size() > 0
        && request.resource.data.author.size() <= 40;
    }

    function hasValidCreatorUid() {
      return signedIn()
        ? request.resource.data.uid == request.auth.uid
        : request.resource.data.uid == null;
    }

    function isValidAuthorRole() {
      return request.resource.data.authorRole in ['user', 'admin']
        && (request.resource.data.authorRole == 'admin' ? isAdmin() : true);
    }

    function keepsPostIdentity() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['title', 'content', 'updatedAt', 'editedBy']);
    }

    function keepsCommentIdentity() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['content', 'updatedAt', 'editedBy']);
    }

    function hasValidEditor() {
      return request.resource.data.editedBy is string
        && request.resource.data.editedBy.size() > 0
        && request.resource.data.editedBy.size() <= 120;
    }

    function existingReactions() {
      return ('reactions' in resource.data) ? resource.data.reactions : {};
    }

    function newReactionCount(reaction) {
      return request.resource.data.reactions.get(reaction, 0);
    }

    function oldReactionCount(reaction) {
      return existingReactions().get(reaction, 0);
    }

    function isValidReactionCount(reaction) {
      return newReactionCount(reaction) is int
        && newReactionCount(reaction) >= oldReactionCount(reaction)
        && newReactionCount(reaction) <= oldReactionCount(reaction) + 1;
    }

    function isValidReactionMap() {
      return request.resource.data.reactions is map
        && request.resource.data.reactions.keys().hasOnly(['공감해요', '응원해요', '따뜻해요', '생각해볼게요'])
        && request.resource.data.reactions.diff(existingReactions()).affectedKeys().size() == 1
        && request.resource.data.reactions.diff(existingReactions()).affectedKeys().hasOnly(['공감해요', '응원해요', '따뜻해요', '생각해볼게요'])
        && isValidReactionCount('공감해요')
        && isValidReactionCount('응원해요')
        && isValidReactionCount('따뜻해요')
        && isValidReactionCount('생각해볼게요');
    }

    function isValidReactionUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
        && isValidReactionMap();
    }

    function isValidPostUpdate() {
      return keepsPostIdentity()
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 80
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 5000
        && request.resource.data.updatedAt == request.time
        && hasValidEditor();
    }

    function isValidCommentUpdate() {
      return keepsCommentIdentity()
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 5000
        && request.resource.data.updatedAt == request.time
        && hasValidEditor();
    }

    function isValidPostCreate() {
      return request.resource.data.keys().hasOnly(['title', 'content', 'createdAt', 'uid', 'author', 'authorRole'])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 80
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 5000
        && request.resource.data.createdAt == request.time
        && isValidAuthor()
        && isValidAuthorRole()
        && hasValidCreatorUid();
    }

    function isValidCommentCreate() {
      return request.resource.data.keys().hasOnly(['content', 'createdAt', 'updatedAt', 'uid', 'author', 'authorRole'])
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 5000
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == null
        && isValidAuthor()
        && isValidAuthorRole()
        && hasValidCreatorUid();
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isValidPostCreate();
      allow update: if ((isOwner() || isAdmin()) && isValidPostUpdate()) || isValidReactionUpdate();
      allow delete: if isOwner() || isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isValidCommentCreate();
        allow update: if ((isOwner() || isAdmin()) && isValidCommentUpdate()) || isValidReactionUpdate();
        allow delete: if isOwner() || isAdmin();
      }
    }

    match /{path=**}/comments/{commentId} {
      allow read: if true;
    }
  }
}
